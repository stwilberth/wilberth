---
import Layout from "../layouts/Layout.astro";

const seller = {
	name: 'Wilberth',
	email: 'info@wilberth.com',
	whatsapp: '+506 85008393'
};

export const title = 'Mantenimiento de Jardines y Propiedades - Puerto Jiménez'
---

<Layout seller={seller} title={title}>
<!-- Hero Section -->
<section class="bg-gradient-to-br from-indigo-900 via-slate-800 to-indigo-900 text-white py-20 mb-12 rounded-b-[3rem] shadow-2xl relative overflow-hidden">
	<div class="absolute inset-0 bg-[url('https://grainy-gradients.vercel.app/noise.svg')] opacity-20 mix-blend-overlay pointer-events-none"></div>
	<div class="max-w-4xl mx-auto text-center relative z-10 px-4">
		<h1 class="text-5xl md:text-6xl font-extrabold mb-6 tracking-tight">Mantenimiento de Jardines</h1>
		<p class="text-xl text-indigo-100 mb-8 max-w-2xl mx-auto font-light">Cuido su propiedad como si fuera mía. Especialista en áreas verdes, jardines y vigilancia en Puerto Jiménez y alrededores.</p>
		<div class="flex flex-col sm:flex-row items-center justify-center gap-4">
			<a href={`https://wa.me/${seller.whatsapp.replace(/[^0-9]/g, '')}?text=Hola! Me interesa el servicio de Mantenimiento de Jardines`} target="_blank" rel="noopener noreferrer" class="bg-emerald-500 text-white px-10 py-4 rounded-full font-bold hover:bg-emerald-600 transition-all shadow-xl hover:-translate-y-1 flex items-center gap-2">
				<svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
					<path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"></path>
				</svg>
				WhatsApp
			</a>
		</div>
	</div>
</section>

<!-- Servicios Detallados -->
<section class="mb-20 px-4">
	<div class="max-w-6xl mx-auto grid md:grid-cols-3 gap-8">
		<div class="bg-white p-8 rounded-3xl shadow-sm border border-emerald-50 hover:shadow-xl transition-all group">
			<div class="w-14 h-14 bg-emerald-100 text-emerald-600 rounded-2xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
				<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"></path>
				</svg>
			</div>
			<h3 class="text-2xl font-bold text-gray-900 mb-4">Jardinería</h3>
			<p class="text-gray-600 leading-relaxed">Corte de césped, poda de árboles, diseño de jardines y mantenimiento constante para que su patio luzca impecable.</p>
		</div>

		<div class="bg-white p-8 rounded-3xl shadow-sm border border-emerald-50 hover:shadow-xl transition-all group">
			<div class="w-14 h-14 bg-emerald-100 text-emerald-600 rounded-2xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
				<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
				</svg>
			</div>
			<h3 class="text-2xl font-bold text-gray-900 mb-4">Vigilancia</h3>
			<p class="text-gray-600 leading-relaxed">Cuido y reporte constante del estado de su propiedad. Vigilancia preventiva y mantenimiento preventivo de infraestructuras.</p>
		</div>

		<div class="bg-white p-8 rounded-3xl shadow-sm border border-emerald-50 hover:shadow-xl transition-all group">
			<div class="w-14 h-14 bg-emerald-100 text-emerald-600 rounded-2xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
				<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
				</svg>
			</div>
			<h3 class="text-2xl font-bold text-gray-900 mb-4">Mantenimiento</h3>
			<p class="text-gray-600 leading-relaxed">Limpieza de canoas, reparaciones menores, pintura y cuidado general de exteriores e interiores.</p>
		</div>
	</div>
</section>

<!-- Tarifa Base -->
<section class="mb-12 px-4">
	<div class="bg-white rounded-[2.5rem] shadow-xl overflow-hidden border border-emerald-100 max-w-4xl mx-auto">
		<div class="p-8 text-center sm:p-12">
			<h2 class="text-3xl font-bold text-gray-900 mb-4">Presupuestos Personalizados</h2>
			<p class="text-lg text-gray-600 mb-8 max-w-2xl mx-auto">Cada propiedad es única. Visito su propiedad y brindo una cotización sin compromiso.</p>
			
			<div class="bg-emerald-50 rounded-3xl p-8 md:p-10 inline-block mx-auto mb-8 border border-emerald-100">
				<span class="text-sm font-semibold text-emerald-700 uppercase tracking-wider mb-2 block">Calidad Garantizada</span>
				<div class="flex items-center justify-center text-emerald-700">
					<span class="text-2xl md:text-3xl font-extrabold italic">Servicio Profesional y Confiable</span>
				</div>
			</div>

			<p class="text-sm text-gray-500 max-w-xl mx-auto italic">
				* Precios competitivos adaptados al tamaño de su finca o lote. Contácteme para agendar una visita.
			</p>
		</div>
	</div>
</section>

<!-- Información de Contacto -->
<section class="bg-gradient-to-br from-emerald-700 to-green-600 text-white rounded-[3rem] shadow-2xl p-10 md:p-16 relative overflow-hidden mb-12 mx-4">
	<div class="absolute inset-0 bg-[url('https://grainy-gradients.vercel.app/noise.svg')] opacity-20 mix-blend-overlay pointer-events-none"></div>
	<div class="text-center relative z-10">
		<h2 class="text-4xl md:text-5xl font-bold mb-6 tracking-tight">¡Coordine su mantenimiento hoy!</h2>
		<p class="text-emerald-100 text-lg mb-10 max-w-xl mx-auto font-light">Escríbame por WhatsApp para programar una visita a su propiedad en Puerto Jiménez.</p>
		<div class="flex flex-col items-center">
			<a href={`https://wa.me/${seller.whatsapp.replace(/[^0-9]/g, '')}?text=Hola! Quiero cotizar el mantenimiento de mi propiedad`} target="_blank" rel="noopener noreferrer" class="bg-white text-emerald-800 px-12 py-4 rounded-full font-bold hover:bg-emerald-50 transition-all shadow-2xl hover:-translate-y-1 flex items-center gap-3 text-lg">
				Agendar Visita por WhatsApp
			</a>
		</div>
	</div>
</section>
</Layout>
