---
import { services } from '../data/services';
import Header from '../components/Header.astro';

// Información del vendedor
const seller = {
	name: 'Wilberth',
	email: 'info@wilberth.com',
	whatsapp: '+506 85008393'
};
const title = 'Wilberth - Productos y Servicios de Calidad';
---

<html lang="es">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<style>
			@tailwind base;
			@tailwind components;
			@tailwind utilities;
		</style>
	</head>
	<body class="bg-slate-50 text-slate-900 font-sans antialiased selection:bg-indigo-500 selection:text-white">
		<Header seller={seller}/>
		<main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-32">
			<!-- Hero Section -->
			<section class="relative mt-8 mb-24 rounded-[3rem] overflow-hidden shadow-[0_20px_50px_rgba(30,41,59,0.15)]">
				<div class="absolute inset-0 bg-gradient-to-br from-indigo-950 via-slate-900 to-indigo-900"></div>
				<div class="absolute inset-0 bg-[url('https://grainy-gradients.vercel.app/noise.svg')] opacity-30 mix-blend-overlay"></div>
				
				<!-- Decorative elements -->
				<div class="absolute -top-24 -right-24 w-64 h-64 bg-indigo-500/20 rounded-full blur-3xl animate-pulse"></div>
				<div class="absolute -bottom-24 -left-24 w-64 h-64 bg-blue-500/10 rounded-full blur-3xl animate-pulse"></div>

				<div class="relative z-10 py-24 md:py-32 px-6 text-center max-w-4xl mx-auto">
					<span class="inline-block px-4 py-1.5 mb-6 text-xs font-bold tracking-[0.2em] uppercase text-indigo-300 bg-indigo-500/10 backdrop-blur-sm border border-indigo-400/20 rounded-full">
						Calidad y Profesionalismo
					</span>
					<h2 class="text-6xl md:text-7xl font-black mb-8 tracking-tighter text-white leading-[1.1]">
						Diseño & <span class="text-transparent bg-clip-text bg-gradient-to-r from-indigo-400 to-blue-300">Soluciones</span> Integrales
					</h2>
					<p class="text-xl md:text-2xl text-slate-300 mb-12 max-w-2xl mx-auto font-light leading-relaxed">
						Impulsamos su visión con productos exclusivos y servicios expertos en Puerto Jiménez y más allá.
					</p>
					<div class="flex flex-col sm:flex-row gap-6 justify-center items-center">
						<a href="#servicios" class="group bg-indigo-500 text-white px-10 py-4 rounded-2xl font-bold transition-all hover:bg-indigo-400 hover:shadow-[0_0_30px_rgba(99,102,241,0.4)] hover:-translate-y-1 flex items-center gap-2">
							Explorar Servicios
							<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
							</svg>
						</a>
						<a href="#productos" class="px-10 py-4 text-white font-bold bg-white/5 backdrop-blur-md border border-white/10 rounded-2xl hover:bg-white/10 transition-all hover:border-white/20">
							Ver Catálogo
						</a>
					</div>
				</div>
			</section>
			<!-- Productos Section -->
			<section id="productos" class="mb-32">
				<div class="flex flex-col md:flex-row md:items-end justify-between mb-16 gap-6 px-4">
					<div class="max-w-xl">
						<h2 class="text-5xl font-black text-slate-900 mb-4 tracking-tight">Nuestros Portales</h2>
						<p class="text-slate-500 text-lg">Visite nuestras tiendas especializadas y descubra una selección curada de artículos de alta gama.</p>
					</div>
					<div class="hidden md:block w-32 h-1.5 bg-indigo-100 rounded-full"></div>
				</div>

				<div class="grid grid-cols-1 md:grid-cols-2 gap-10 px-4">
					<!-- Categoría Relojes -->
					<a
						href="https://invictacostarica.com"
						target="_blank"
						rel="noopener noreferrer"
						class="group relative h-80 rounded-[2.5rem] overflow-hidden bg-slate-900 shadow-2xl transition-all duration-500 hover:-translate-y-2"
					>
						<div class="absolute inset-0 bg-gradient-to-t from-indigo-950 via-indigo-950/40 to-transparent z-10"></div>
						<div class="absolute inset-0 bg-indigo-600 opacity-0 group-hover:opacity-20 transition-opacity duration-500 z-10"></div>
						
						<!-- Simulación de imagen de fondo -->
						<div class="absolute inset-0 flex items-center justify-center opacity-40 group-hover:scale-110 transition-transform duration-700">
							<svg class="w-48 h-48 text-indigo-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="0.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
							</svg>
						</div>

						<div class="absolute inset-0 z-20 p-10 flex flex-col justify-end">
							<div class="w-14 h-14 bg-white/10 backdrop-blur-md border border-white/20 rounded-2xl flex items-center justify-center mb-4 group-hover:bg-indigo-500 transition-colors duration-300 shadow-xl">
								<svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
								</svg>
							</div>
							<h3 class="text-3xl font-black text-white tracking-tight mb-2">Relojes de Lujo</h3>
							<p class="text-indigo-200 font-medium">Invicta Costa Rica & More</p>
						</div>
					</a>

					<!-- Categoría Artículos de pesca -->
					<a
						href="https://osafishingprocr.com"
						target="_blank"
						rel="noopener noreferrer"
						class="group relative h-80 rounded-[2.5rem] overflow-hidden bg-slate-900 shadow-2xl transition-all duration-500 hover:-translate-y-2"
					>
						<div class="absolute inset-0 bg-gradient-to-t from-slate-950 via-slate-950/40 to-transparent z-10"></div>
						<div class="absolute inset-0 bg-blue-600 opacity-0 group-hover:opacity-20 transition-opacity duration-500 z-10"></div>
						
						<!-- Simulación de imagen de fondo -->
						<div class="absolute inset-0 flex items-center justify-center opacity-40 group-hover:scale-110 transition-transform duration-700">
							<svg class="w-48 h-48 text-blue-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="0.5" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z" />
							</svg>
						</div>

						<div class="absolute inset-0 z-20 p-10 flex flex-col justify-end">
							<div class="w-14 h-14 bg-white/10 backdrop-blur-md border border-white/20 rounded-2xl flex items-center justify-center mb-4 group-hover:bg-blue-500 transition-colors duration-300 shadow-xl">
								<svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z" />
								</svg>
							</div>
							<h3 class="text-3xl font-black text-white tracking-tight mb-2">Pasión por la Pesca</h3>
							<p class="text-blue-200 font-medium">Osa Fishing Pro CR</p>
						</div>
					</a>
				</div>
			</section>

			<!-- Servicios Section -->
			<section id="servicios" class="mb-32">
				<div class="text-center mb-20 px-4">
					<span class="text-indigo-600 font-black uppercase tracking-[0.3em] text-sm mb-4 block">Especialidad</span>
					<h2 class="text-5xl font-black text-slate-900 mb-6 tracking-tight">Nuestros Servicios</h2>
					<div class="w-20 h-2 bg-indigo-500 mx-auto rounded-full mb-8"></div>
					<p class="text-slate-500 text-xl max-w-2xl mx-auto font-light">Experiencia técnica y compromiso personal en cada proyecto.</p>
				</div>

				<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-10 px-4">
					{services.map((service) => (
						<div class="group bg-white rounded-[2rem] shadow-[0_10px_30px_rgba(0,0,0,0.02)] border border-slate-100 overflow-hidden hover:shadow-2xl transition-all duration-500 hover:-translate-y-3 h-full flex flex-col relative">
							<!-- Imagen como enlace -->
							<a 
								href={`/${service.slug}`}
								class="block flex-grow"
							>
								<div class="h-60 bg-slate-50 flex items-center justify-center p-8 border-b border-slate-50 overflow-hidden relative">
									<div class="absolute inset-0 bg-indigo-600 opacity-0 group-hover:opacity-5 transition-opacity duration-300"></div>
									<img
										src={service.image_url}
										alt={service.name}
										class="h-full w-auto object-contain group-hover:scale-110 transition-transform duration-700"
										loading="lazy"
									/>
									<div class="absolute top-6 right-6 opacity-0 group-hover:opacity-100 transition-opacity">
										<div class="w-10 h-10 bg-white shadow-lg rounded-xl flex items-center justify-center">
											<svg class="w-5 h-5 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M14 5l7 7m0 0l-7 7m7-7H3" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path></svg>
										</div>
									</div>
								</div>

								<div class="p-10 flex-grow">
									<h3 class="text-2xl font-black text-slate-900 mb-4 group-hover:text-indigo-600 transition-colors leading-tight">{service.name}</h3>
									<p class="text-slate-500 leading-relaxed font-light">{service.description}</p>
								</div>
							</a>

							<!-- Pie de tarjeta con botón -->
							<div class="px-10 pb-10 mt-auto">
								<div class="flex items-center justify-end border-t border-slate-50 pt-8 mt-2">									
									<a
										href={`https://wa.me/${seller.whatsapp.replace(/[^0-9]/g, '')}?text=Hola! Estoy interesado en el servicio de ${encodeURIComponent(service.name)}`}
										target="_blank"
										rel="noopener noreferrer"
										class="bg-emerald-500 text-white px-6 py-3 rounded-2xl text-sm font-bold flex items-center gap-2 transition-all hover:bg-emerald-600 hover:shadow-[0_10px_20px_rgba(16,185,129,0.3)] hover:scale-105"
									>
										<svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
											<path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
										</svg>
										<span>Consultar</span>
									</a>
								</div>
							</div>
						</div>
					))}
				</div>
			</section>

			<!-- Contacto Section -->
			<section class="relative bg-slate-900 rounded-[3rem] shadow-3xl p-12 md:p-24 overflow-hidden">
				<div class="absolute inset-0 bg-gradient-to-br from-indigo-950 via-slate-950 to-indigo-900 opacity-90"></div>
				<div class="absolute inset-0 bg-[url('https://grainy-gradients.vercel.app/noise.svg')] opacity-20 mix-blend-overlay"></div>
				
				<div class="relative z-10 grid lg:grid-cols-2 gap-20 items-center">
					<div>
						<h2 class="text-6xl font-black text-white mb-8 tracking-tighter leading-tight">¿Hablamos de su <span class="text-indigo-400">próximo</span> proyecto?</h2>
						<p class="text-xl text-slate-300 mb-12 font-light leading-relaxed">Le responderemos en menos de 24 horas. Estamos listos para llevar su negocio o propiedad al siguiente nivel.</p>
						
						<div class="flex flex-col gap-6">
							<div class="flex items-center gap-6 group">
								<div class="w-16 h-16 bg-white/5 border border-white/10 rounded-2xl flex items-center justify-center transition-all group-hover:bg-indigo-500 group-hover:scale-110 shadow-xl">
									<svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
								</div>
								<div>
									<h4 class="text-white font-bold text-lg">Vendedor Principal</h4>
									<p class="text-slate-400">{seller.name}</p>
								</div>
							</div>
							
							<div class="flex items-center gap-6 group">
								<div class="w-16 h-16 bg-white/5 border border-white/10 rounded-2xl flex items-center justify-center transition-all group-hover:bg-blue-500 group-hover:scale-110 shadow-xl">
									<svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
								</div>
								<div>
									<h4 class="text-white font-bold text-lg">Correo Electrónico</h4>
									<a href={`mailto:${seller.email}`} class="text-slate-400 hover:text-white transition-colors">{seller.email}</a>
								</div>
							</div>
						</div>
					</div>

					<div class="bg-white/5 backdrop-blur-xl border border-white/10 p-12 rounded-[2.5rem] text-center shadow-2xl relative overflow-hidden group">
						<div class="absolute -top-12 -right-12 w-48 h-48 bg-emerald-500/10 rounded-full blur-2xl group-hover:bg-emerald-500/20 transition-all"></div>
						
						<div class="w-24 h-24 bg-emerald-500 text-white rounded-[2rem] flex items-center justify-center mx-auto mb-8 shadow-2xl shadow-emerald-500/30 transform group-hover:scale-110 transition-transform duration-500">
							<svg class="w-12 h-12" fill="currentColor" viewBox="0 0 24 24">
								<path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"></path>
							</svg>
						</div>
						
						<h3 class="text-3xl font-black text-white mb-4">Directo a WhatsApp</h3>
						<p class="text-slate-400 mb-8 font-light">Escríbanos un mensaje y le atenderemos con gusto.</p>
						
						<a 
							href={`https://wa.me/${seller.whatsapp.replace(/[^0-9]/g, '')}`}
							target="_blank"
							rel="noopener noreferrer"
							class="inline-block w-full py-5 bg-white text-slate-900 rounded-2xl font-black text-lg hover:bg-indigo-500 hover:text-white transition-all shadow-xl active:scale-95"
						>
							Abrir Chat Ahora
						</a>
					</div>
				</div>
			</section>
		</main>

		<script>
			// Lógica simplificada
		</script>
	</body>
</html>
