---
import { getProducts, createTables, type Product } from '../lib/db';
import { services } from '../data/services';
import Header from '../components/Header.astro';
await createTables();
let products: Product[] = [];
try {
  products = await getProducts();
} catch (error) {
  console.error('Error fetching products:', error);
  products = [];
}

// Información del vendedor
const seller = {
	name: 'Wilberth',
	email: 'info@wilberth.com',
	whatsapp: '+506 85008393'
};
const title = 'Wilberth - Productos y Servicios de Calidad';
---

<html lang="es">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<style>
			@tailwind base;
			@tailwind components;
			@tailwind utilities;
		</style>
	</head>
	<body class="bg-gradient-to-br from-gray-50 to-gray-100 text-gray-900 font-sans antialiased">
		<Header seller={seller}/>
		<main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-16">
			<!-- Hero Section -->
			<section class="bg-gradient-to-r from-blue-600 to-blue-800 text-white py-16 mb-12">
				<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
					<h2 class="text-4xl md:text-5xl font-bold mb-4">Bienvenido a mi Página</h2>
					<p class="text-xl text-blue-100 mb-4 max-w-2xl mx-auto">Encuentra productos de calidad y servicios profesionales.</p>
					<p class="text-xl text-blue-100 mb-8 max-w-2xl mx-auto">¡Contáctame para más información!</p>
					<div class="flex flex-col sm:flex-row gap-4 justify-center">
						<a href="#productos" class="bg-white text-blue-600 px-8 py-3 rounded-lg font-semibold hover:bg-blue-50 transition-colors shadow-lg inline-block">
							Ver Productos
						</a>
						<a href="#servicios" class="bg-blue-500 text-white px-8 py-3 rounded-lg font-semibold hover:bg-blue-400 transition-colors shadow-lg inline-block">
							Ver Servicios
						</a>
					</div>
				</div>
			</section>
			<!-- Productos Section -->
			<section id="productos" class="mb-20">
				<div class="text-center mb-10">
					<h2 class="text-4xl font-bold text-gray-900 mb-3">Nuestros Productos</h2>
					<p class="text-gray-600 text-lg">Explora nuestra selección de productos de calidad</p>
				</div>

				<!-- Filtros de Categoría -->
				<div class="grid grid-cols-1 sm:grid-cols-2 gap-6 max-w-4xl mx-auto mb-10">
					<!-- Categoría Relojes -->
					<a
						href="https://invictacostarica.com"
						target="_blank"
						rel="noopener noreferrer"
						class="group bg-white rounded-xl p-6 shadow-lg transition-all duration-300 hover:shadow-2xl hover:-translate-y-2 hover:bg-blue-50 border-2 border-transparent hover:border-blue-200"
					>
						<div class="text-center">
							<div class="w-12 h-12 bg-blue-100 rounded-xl flex items-center justify-center mx-auto mb-3 group-hover:bg-blue-200 transition-colors">
								<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
								</svg>
							</div>
							<h3 class="text-lg font-semibold text-gray-800 group-hover:text-blue-700 transition-colors">Relojes</h3>
						</div>
					</a>

					<!-- Categoría Artículos de pesca -->
					<a
						href="https://osafishingprocr.com"
						target="_blank"
						rel="noopener noreferrer"
						class="group bg-white rounded-xl p-6 shadow-lg transition-all duration-300 hover:shadow-2xl hover:-translate-y-2 hover:bg-blue-50 border-2 border-transparent hover:border-blue-200"
					>
						<div class="text-center">
							<div class="w-12 h-12 bg-blue-100 rounded-xl flex items-center justify-center mx-auto mb-3 group-hover:bg-blue-200 transition-colors">
								<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z" />
								</svg>
							</div>
							<h3 class="text-lg font-semibold text-gray-800 group-hover:text-blue-700 transition-colors">Artículos de pesca</h3>
						</div>
					</a>
				</div>
			</section>

			<!-- Servicios Section -->
			<section id="servicios" class="py-16 bg-gray-50">
				<div class="container mx-auto px-4">
					<div class="text-center mb-12">
						<h2 class="text-4xl font-bold text-gray-900 mb-3">Nuestros Servicios</h2>
						<div class="w-24 h-1 bg-purple-600 mx-auto mb-4"></div>
						<p class="text-gray-600 text-lg max-w-2xl mx-auto">Servicios profesionales adaptados a tus necesidades</p>
					</div>

					<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 px-4">
						{services.map((service) => (
							<div class="bg-white rounded-lg shadow-md overflow-hidden hover:shadow-lg transition-all duration-300 h-full flex flex-col">
								<!-- Imagen como enlace -->
								<a 
									href={
										service.name === 'Express' ? '/express' :
										service.name === 'Desarrollo de Aplicaciones Web' ? '/desarrollo-web' :
										service.name === 'Cortiz' ? '/cortiz' :
										'/paginas-web'
									}
									class="block flex-grow"
								>
									<div class="h-48 bg-gray-100 flex items-center justify-center p-4">
										<img
											src={service.image_url}
											alt={service.name}
											class="h-full w-auto object-contain"
											loading="lazy"
										/>
									</div>

									<div class="p-5 flex-grow">
										<h3 class="text-xl font-bold text-gray-900 mb-2">{service.name}</h3>
										<p class="text-gray-600 text-sm mb-4">{service.description}</p>
									</div>
								</a>

								<!-- Pie de tarjeta con precio y botón -->
								<div class="p-5 pt-0 mt-auto">
									<div class="flex items-center justify-between border-t border-gray-100 pt-4">
										<span class="text-lg font-semibold text-purple-600">
											{service.price > 0 ? `₡${service.price.toLocaleString()}` : 'Consultar'}
										</span>
										
										<a
											href={`https://wa.me/${seller.whatsapp.replace(/[^0-9]/g, '')}?text=Hola! Estoy interesado en el servicio de ${encodeURIComponent(service.name)}`}
											target="_blank"
											rel="noopener noreferrer"
											class="bg-green-500 hover:bg-green-600 text-white px-3 py-1.5 rounded text-sm font-medium flex items-center gap-1 transition-colors"
										>
											<svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24">
												<path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
											</svg>
											<span>Consultar</span>
										</a>
									</div>
								</div>
							</div>
						))}
					</div>
				</div>
			</section>

			<!-- Contacto Section -->
			<section class="bg-gradient-to-r from-blue-600 to-blue-800 text-white rounded-2xl shadow-2xl p-8 md:p-12">
				<div class="text-center mb-8">
					<h2 class="text-3xl md:text-4xl font-bold mb-3">¿Tienes preguntas?</h2>
					<p class="text-blue-100 text-lg">Estoy aquí para ayudarte. ¡Contáctame ahora!</p>
				</div>
				<div class="grid md:grid-cols-3 gap-6 max-w-4xl mx-auto">
					<div class="bg-white/10 backdrop-blur-sm rounded-xl p-6 text-center hover:bg-white/20 transition-colors">
						<div class="w-16 h-16 bg-white text-blue-600 rounded-full flex items-center justify-center mx-auto mb-4 shadow-lg">
							<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
							</svg>
						</div>
						<h3 class="font-bold text-xl mb-2">Vendedor</h3>
						<p class="text-blue-100">{seller.name}</p>
					</div>
					<div class="bg-white/10 backdrop-blur-sm rounded-xl p-6 text-center hover:bg-white/20 transition-colors">
						<div class="w-16 h-16 bg-white text-blue-600 rounded-full flex items-center justify-center mx-auto mb-4 shadow-lg">
							<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
							</svg>
						</div>
						<h3 class="font-bold text-xl mb-2">Email</h3>
						<a href={`mailto:${seller.email}`} class="text-blue-100 hover:text-white transition-colors">
							{seller.email}
						</a>
					</div>
					<div class="bg-white/10 backdrop-blur-sm rounded-xl p-6 text-center hover:bg-white/20 transition-colors">
						<div class="w-16 h-16 bg-green-500 text-white rounded-full flex items-center justify-center mx-auto mb-4 shadow-lg">
							<svg class="w-8 h-8" fill="currentColor" viewBox="0 0 24 24">
								<path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"></path>
							</svg>
						</div>
						<h3 class="font-bold text-xl mb-2">WhatsApp</h3>
						<a
							href={`https://wa.me/${seller.whatsapp.replace(/[^0-9]/g, '')}`}
							target="_blank"
							rel="noopener noreferrer"
							class="text-blue-100 hover:text-white transition-colors"
						>
							{seller.whatsapp}
						</a>
					</div>
				</div>
			</section>
		</main>

		<!-- JavaScript para filtros de categoría -->
		<script>
			document.addEventListener('DOMContentLoaded', () => {
				const filterButtons = document.querySelectorAll<HTMLButtonElement>('.category-filter');
				const productCards = document.querySelectorAll<HTMLDivElement>('.product-card');
				const noProductsMessage = document.getElementById('no-products');

				filterButtons.forEach(button => {
					button.addEventListener('click', () => {
						const category = button.dataset.category || 'all';

						// Update active button
						filterButtons.forEach(btn => {
							if (btn === button) {
								btn.classList.remove('bg-white', 'text-gray-700');
								btn.classList.add('bg-blue-600', 'text-white');
							} else {
								btn.classList.remove('bg-blue-600', 'text-white');
								btn.classList.add('bg-white', 'text-gray-700');
							}
						});

						// Filter products
						let visibleCount = 0;
						productCards.forEach(card => {
							const cardCategory = card.dataset.category || '';
							if (category === 'all' || cardCategory === category) {
								card.style.display = 'block';
								visibleCount++;
							} else {
								card.style.display = 'none';
							}
						});

						// Show/hide no products message
						if (noProductsMessage) {
							if (visibleCount === 0) {
								noProductsMessage.classList.remove('hidden');
							} else {
								noProductsMessage.classList.add('hidden');
							}
						}
					});
				});
			});
		</script>
	</body>
</html>
