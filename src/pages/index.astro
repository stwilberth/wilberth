---
import { getProducts, getServices, createTables } from '../lib/db';

await createTables();
const products = await getProducts();
const services = await getServices();

// Información del vendedor
const seller = {
	name: 'Wilberth',
	email: 'info@wilberth.com',
	whatsapp: '+506 85008393'
};
---

<html lang="es">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="generator" content={Astro.generator} />
		<title>Wilberth - Productos y Servicios de Calidad</title>
		<style>
			@tailwind base;
			@tailwind components;
			@tailwind utilities;
		</style>
	</head>
	<body class="bg-gradient-to-br from-gray-50 to-gray-100 text-gray-900 font-sans antialiased">
		<main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-16">
			<!-- Hero Section -->
			<section class="bg-gradient-to-r from-blue-600 to-blue-800 text-white py-16 mb-12">
				<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
					<h2 class="text-4xl md:text-5xl font-bold mb-4">Bienvenido a mi tienda</h2>
					<p class="text-xl text-blue-100 mb-8 max-w-2xl mx-auto">Encuentra productos de calidad y servicios profesionales. ¡Contáctame para más información!</p>
					<div class="flex flex-col sm:flex-row gap-4 justify-center">
						<a href="#productos" class="bg-white text-blue-600 px-8 py-3 rounded-lg font-semibold hover:bg-blue-50 transition-colors shadow-lg inline-block">
							Ver Productos
						</a>
						<a href="#servicios" class="bg-blue-500 text-white px-8 py-3 rounded-lg font-semibold hover:bg-blue-400 transition-colors shadow-lg inline-block">
							Ver Servicios
						</a>
					</div>
				</div>
			</section>
			<!-- Productos Section -->
			<section id="productos" class="mb-20">
				<div class="text-center mb-10">
					<h2 class="text-4xl font-bold text-gray-900 mb-3">Nuestros Productos</h2>
					<p class="text-gray-600 text-lg">Explora nuestra selección de productos de calidad</p>
				</div>

				<!-- Filtros de Categoría -->
				<div class="flex flex-wrap justify-center gap-3 mb-10">
					<button
						class="category-filter px-6 py-2 rounded-full font-medium transition-all shadow-md bg-blue-600 text-white hover:bg-blue-700"
						data-category="all"
					>
						Todos
					</button>
					<button
						class="category-filter px-6 py-2 rounded-full font-medium transition-all shadow-md bg-white text-gray-700 hover:bg-gray-100"
						data-category="Reloj"
					>
						⌚ Relojes
					</button>
					<button
						class="category-filter px-6 py-2 rounded-full font-medium transition-all shadow-md bg-white text-gray-700 hover:bg-gray-100"
						data-category="Auto usado"
					>
						🚗 Autos Usados
					</button>
					<button
						class="category-filter px-6 py-2 rounded-full font-medium transition-all shadow-md bg-white text-gray-700 hover:bg-gray-100"
						data-category="Hogar"
					>
						🏠 Hogar
					</button>
					<button
						class="category-filter px-6 py-2 rounded-full font-medium transition-all shadow-md bg-white text-gray-700 hover:bg-gray-100"
						data-category="Artículos de pesca"
					>
						🎣 Artículos de pesca
					</button>
				</div>

				<!-- Grid de Productos -->
				<div id="products-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
					{products.map(product => (
						<div class="product-card bg-white rounded-xl shadow-lg overflow-hidden transition-all hover:shadow-2xl hover:-translate-y-2 duration-300" data-category={product.category}>
							<div class="relative overflow-hidden h-56 bg-gradient-to-br from-gray-100 to-gray-200">
								<img
									src={product.image_url}
									alt={product.name}
									class="w-full h-full object-cover transition-transform duration-300 hover:scale-110"
								/>
								<div class="absolute top-3 right-3">
									<span class="bg-blue-600 text-white px-3 py-1 rounded-full text-xs font-semibold shadow-md">
										{product.category}
									</span>
								</div>
							</div>
							<div class="p-5">
								<h3 class="text-xl font-bold text-gray-900 mb-2">{product.name}</h3>
								<p class="text-gray-600 text-sm mb-4 line-clamp-2">{product.description}</p>
								<div class="flex items-center justify-between">
									<p class="text-2xl font-bold text-blue-600">${product.price}</p>
									<a
										href={`https://wa.me/${seller.whatsapp.replace(/[^0-9]/g, '')}?text=Hola! Estoy interesado en ${product.name}`}
										target="_blank"
										rel="noopener noreferrer"
										class="bg-green-500 hover:bg-green-600 text-white px-4 py-2 rounded-lg text-sm font-medium transition-colors shadow-md flex items-center gap-2"
									>
										<svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
											<path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"></path>
										</svg>
										Consultar
									</a>
								</div>
							</div>
						</div>
					))}
				</div>

				<!-- Mensaje si no hay productos -->
				<div id="no-products" class="hidden text-center py-16">
					<div class="text-gray-400 mb-4">
						<svg class="w-20 h-20 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4"></path>
						</svg>
					</div>
					<h3 class="text-2xl font-semibold text-gray-700 mb-2">No hay productos en esta categoría</h3>
					<p class="text-gray-500">Intenta con otra categoría o contacta al vendedor</p>
				</div>
			</section>

			<!-- Servicios Section -->
			<section id="servicios" class="mb-20">
				<div class="text-center mb-10">
					<h2 class="text-4xl font-bold text-gray-900 mb-3">Nuestros Servicios</h2>
					<p class="text-gray-600 text-lg">Servicios profesionales adaptados a tus necesidades</p>
				</div>

				<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
					{services.map(service => (
						<a href={service.name === 'Express' ? '/servicios/express' : service.name === 'Desarrollo de Aplicaciones Web' ? '/servicios/desarrollo-web' : service.name === 'Cortiz' ? '/servicios/cortiz' : service.name === 'Páginas web' ? '/servicios/paginas-web' : '#'} class="block bg-white rounded-xl shadow-lg overflow-hidden transition-all hover:shadow-2xl hover:-translate-y-2 duration-300">
							<div class="relative overflow-hidden h-56 bg-gradient-to-br from-purple-100 to-purple-200">
								<img
									src={service.image_url}
									alt={service.name}
									class="w-full h-full object-cover transition-transform duration-300 hover:scale-110"
								/>
							</div>
							<div class="p-5">
								<h3 class="text-xl font-bold text-gray-900 mb-2">{service.name}</h3>
								<p class="text-gray-600 text-sm mb-4">{service.description}</p>
								<div class="flex items-center justify-between">
									<p class="text-lg font-semibold text-purple-600">desde ₡{service.price.toLocaleString()}</p>
									<a
										href={`https://wa.me/${seller.whatsapp.replace(/[^0-9]/g, '')}?text=Hola! Estoy interesado en el servicio de ${service.name}`}
										target="_blank"
										rel="noopener noreferrer"
										onclick="event.stopPropagation()"
										class="bg-green-500 hover:bg-green-600 text-white px-4 py-2 rounded-lg text-sm font-medium transition-colors shadow-md flex items-center gap-2"
									>
										<svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
											<path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"></path>
										</svg>
										Consultar
									</a>
								</div>
							</div>
						</a>
					))}
				</div>
			</section>

			<!-- Contacto Section -->
			<section class="bg-gradient-to-r from-blue-600 to-blue-800 text-white rounded-2xl shadow-2xl p-8 md:p-12">
				<div class="text-center mb-8">
					<h2 class="text-3xl md:text-4xl font-bold mb-3">¿Tienes preguntas?</h2>
					<p class="text-blue-100 text-lg">Estoy aquí para ayudarte. ¡Contáctame ahora!</p>
				</div>
				<div class="grid md:grid-cols-3 gap-6 max-w-4xl mx-auto">
					<div class="bg-white/10 backdrop-blur-sm rounded-xl p-6 text-center hover:bg-white/20 transition-colors">
						<div class="w-16 h-16 bg-white text-blue-600 rounded-full flex items-center justify-center mx-auto mb-4 shadow-lg">
							<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
							</svg>
						</div>
						<h3 class="font-bold text-xl mb-2">Vendedor</h3>
						<p class="text-blue-100">{seller.name}</p>
					</div>
					<div class="bg-white/10 backdrop-blur-sm rounded-xl p-6 text-center hover:bg-white/20 transition-colors">
						<div class="w-16 h-16 bg-white text-blue-600 rounded-full flex items-center justify-center mx-auto mb-4 shadow-lg">
							<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
							</svg>
						</div>
						<h3 class="font-bold text-xl mb-2">Email</h3>
						<a href={`mailto:${seller.email}`} class="text-blue-100 hover:text-white transition-colors">
							{seller.email}
						</a>
					</div>
					<div class="bg-white/10 backdrop-blur-sm rounded-xl p-6 text-center hover:bg-white/20 transition-colors">
						<div class="w-16 h-16 bg-green-500 text-white rounded-full flex items-center justify-center mx-auto mb-4 shadow-lg">
							<svg class="w-8 h-8" fill="currentColor" viewBox="0 0 24 24">
								<path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"></path>
							</svg>
						</div>
						<h3 class="font-bold text-xl mb-2">WhatsApp</h3>
						<a
							href={`https://wa.me/${seller.whatsapp.replace(/[^0-9]/g, '')}`}
							target="_blank"
							rel="noopener noreferrer"
							class="text-blue-100 hover:text-white transition-colors"
						>
							{seller.whatsapp}
						</a>
					</div>
				</div>
			</section>
		</main>

		<!-- JavaScript para filtros de categoría -->
		<script>
			document.addEventListener('DOMContentLoaded', () => {
				const filterButtons = document.querySelectorAll<HTMLButtonElement>('.category-filter');
				const productCards = document.querySelectorAll<HTMLDivElement>('.product-card');
				const noProductsMessage = document.getElementById('no-products');

				filterButtons.forEach(button => {
					button.addEventListener('click', () => {
						const category = button.dataset.category || 'all';

						// Update active button
						filterButtons.forEach(btn => {
							if (btn === button) {
								btn.classList.remove('bg-white', 'text-gray-700');
								btn.classList.add('bg-blue-600', 'text-white');
							} else {
								btn.classList.remove('bg-blue-600', 'text-white');
								btn.classList.add('bg-white', 'text-gray-700');
							}
						});

						// Filter products
						let visibleCount = 0;
						productCards.forEach(card => {
							const cardCategory = card.dataset.category || '';
							if (category === 'all' || cardCategory === category) {
								card.style.display = 'block';
								visibleCount++;
							} else {
								card.style.display = 'none';
							}
						});

						// Show/hide no products message
						if (noProductsMessage) {
							if (visibleCount === 0) {
								noProductsMessage.classList.remove('hidden');
							} else {
								noProductsMessage.classList.add('hidden');
							}
						}
					});
				});
			});
		</script>
	</body>
</html>
