---
import Header from "../components/Header.astro";
import { projects } from "../data/projects";

import leivaTours from "../assets/covers/www.leivatours.com_.png";
import ranchoRaices from "../assets/covers/ranchoraices.com_.png";
import invictaCr from "../assets/covers/invictacostarica.com_.png";
import variedadesCr from "../assets/covers/variedadescr.com_.png";
import osaFishing from "../assets/covers/osafishingprocr.com_.png";
import osaTours from "../assets/covers/osatoursandtravel.com_.png";
import type { ImageMetadata } from "astro";

const coverMap: Record<string, ImageMetadata> = {
    "leiva-tours": leivaTours,
    "rancho-raices": ranchoRaices,
    "invicta-costa-rica": invictaCr,
    "variedades-cr": variedadesCr,
    "osa-fishing-pro-cr": osaFishing,
    "osa-tours-and-travel": osaTours,
};

const seller = { name: "Wilberth", whatsapp: "+506 85008393" };
const title = "Proyectos - Wilberth";
---

<html lang="es">
    <head>
        <meta charset="utf-8" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <meta name="generator" content={Astro.generator} />
        <title>{title}</title>
        <style>
            @tailwind base;
            @tailwind components;
            @tailwind utilities;
        </style>
    </head>
    <body
        class="bg-slate-50 text-slate-900 font-sans antialiased selection:bg-indigo-500 selection:text-white"
    >
        <Header seller={seller} />
        <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-32">
            <!-- Encabezado -->
            <section class="pt-16 pb-12 px-4">
                <div class="max-w-xl mx-auto text-center">
                    <span
                        class="text-indigo-600 font-black uppercase tracking-[0.3em] text-sm mb-4 block"
                        >Portafolio</span
                    >
                    <h1
                        class="text-5xl font-black text-slate-900 mb-4 tracking-tight"
                    >
                        Proyectos Realizados
                    </h1>
                    <p class="text-slate-500 text-lg">
                        Sitios web que he creado para emprendedores y negocios
                        en Costa Rica.
                    </p>
                    <div
                        class="w-20 h-2 bg-indigo-500 mx-auto rounded-full mt-8"
                    >
                    </div>
                </div>
            </section>

            <!-- Grid de proyectos -->
            <div
                class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10 px-4"
            >
                {
                    projects.map((project) => {
                        const cover = coverMap[project.slug];
                        return (
                            <a
                                href={`/portafolio/${project.slug}`}
                                class="group relative h-72 rounded-[2.5rem] overflow-hidden bg-slate-900 shadow-2xl transition-all duration-500 hover:-translate-y-2"
                                style={{
                                    backgroundImage: `url(${cover.src})`,
                                    backgroundSize: "cover",
                                    backgroundPosition: "top",
                                }}
                            >
                                <div
                                    class={`absolute inset-0 bg-gradient-to-t ${project.gradientFrom} ${project.gradientVia} ${project.gradientTo} z-10`}
                                />
                                <div
                                    class={`absolute inset-0 ${project.hoverColor} opacity-0 group-hover:opacity-20 transition-opacity duration-500 z-10`}
                                />
                                <div class="absolute inset-0 flex items-center justify-center opacity-30 group-hover:scale-110 transition-transform duration-700">
                                    <svg
                                        class={`w-48 h-48 ${project.iconColor}`}
                                        fill="none"
                                        stroke="currentColor"
                                        viewBox="0 0 24 24"
                                    >
                                        <path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            stroke-width="0.5"
                                            d={project.svgPath}
                                        />
                                    </svg>
                                </div>
                                <div class="absolute inset-0 z-20 p-8 flex flex-col justify-end">
                                    <h3 class="text-2xl font-black text-white tracking-tight mb-1">
                                        {project.name}
                                    </h3>
                                    <p
                                        class={`text-sm font-medium ${project.categoryColor}`}
                                    >
                                        {project.category}
                                    </p>
                                </div>
                            </a>
                        );
                    })
                }
            </div>
        </main>
    </body>
</html>
