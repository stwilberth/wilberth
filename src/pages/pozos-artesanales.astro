---
import Layout from "../layouts/Layout.astro";

const seller = {
	name: 'Wilberth',
	email: 'info@wilberth.com',
	whatsapp: '+506 85008393'
};

export const title = 'Creación de Pozos Artesanales en Costa Rica'
---

<Layout seller={seller} title={title}>
<!-- Hero Section -->
<section class="bg-gradient-to-br from-indigo-900 via-slate-800 to-indigo-900 text-white py-20 mb-12 rounded-b-[3rem] shadow-2xl relative overflow-hidden">
	<div class="absolute inset-0 bg-[url('https://grainy-gradients.vercel.app/noise.svg')] opacity-20 mix-blend-overlay pointer-events-none"></div>
	<div class="max-w-4xl mx-auto text-center relative z-10 px-4">
		<h1 class="text-5xl md:text-6xl font-extrabold mb-6 tracking-tight">Pozos Artesanales</h1>
		<p class="text-xl text-indigo-100 mb-8 max-w-2xl mx-auto font-light">Especialista en la construcción de pozos de agua con técnicas artesanales. Agua pura y natural para su hogar o finca.</p>
		<div class="flex flex-col sm:flex-row items-center justify-center gap-4">
			<a href={`https://wa.me/${seller.whatsapp.replace(/[^0-9]/g, '')}?text=Hola! Me interesa información sobre la construcción de un pozo artesanal`} target="_blank" rel="noopener noreferrer" class="bg-cyan-500 text-white px-10 py-4 rounded-full font-bold hover:bg-cyan-600 transition-all shadow-xl hover:-translate-y-1 flex items-center gap-2">
				<svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
					<path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"></path>
				</svg>
				WhatsApp
			</a>
		</div>
	</div>
</section>

<!-- Proceso Artístico y Funcional -->
<section class="mb-20 px-4">
	<div class="max-w-6xl mx-auto grid md:grid-cols-2 gap-12 items-center">
		<div>
			<h2 class="text-4xl font-extrabold text-gray-900 mb-6 tracking-tight">Experiencia y Tradición</h2>
			<div class="space-y-6">
				<div class="flex gap-4">
					<div class="flex-shrink-0 w-10 h-10 bg-cyan-100 text-cyan-600 rounded-lg flex items-center justify-center font-bold">1</div>
					<p class="text-gray-600 leading-relaxed text-lg">Localizamos el punto óptimo de agua por medio de métodos tradicionales y conocimiento del terreno en Osa.</p>
				</div>
				<div class="flex gap-4">
					<div class="flex-shrink-0 w-10 h-10 bg-cyan-100 text-cyan-600 rounded-lg flex items-center justify-center font-bold">2</div>
					<p class="text-gray-600 leading-relaxed text-lg">Excavación manual cuidadosa, garantizando la estabilidad y el flujo constante de agua natural.</p>
				</div>
				<div class="flex gap-4">
					<div class="flex-shrink-0 w-10 h-10 bg-cyan-100 text-cyan-600 rounded-lg flex items-center justify-center font-bold">3</div>
					<p class="text-gray-600 leading-relaxed text-lg">Acabados estéticos y funcionales, integrando el pozo al paisaje de su propiedad.</p>
				</div>
			</div>
		</div>
		<div class="bg-cyan-50 p-1 rounded-[3rem] shadow-inner overflow-hidden border border-cyan-100">
			<div class="bg-white p-8 rounded-[2.8rem] shadow-sm text-center">
				<h3 class="text-2xl font-bold text-gray-900 mb-4">Ventajas</h3>
				<ul class="text-left space-y-4 text-gray-600">
					<li class="flex items-center gap-2">
						<svg class="w-5 h-5 text-cyan-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
						Bajo costo de mantenimiento
					</li>
					<li class="flex items-center gap-2">
						<svg class="w-5 h-5 text-cyan-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
						Independencia de acueductos
					</li>
					<li class="flex items-center gap-2">
						<svg class="w-5 h-5 text-cyan-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
						Agua fresca para riego y uso general
					</li>
					<li class="flex items-center gap-2">
						<svg class="w-5 h-5 text-cyan-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
						Valor agregado a su propiedad
					</li>
				</ul>
			</div>
		</div>
	</div>
</section>

<!-- Tarifa Base -->
<section class="mb-12 px-4">
	<div class="bg-white rounded-[2.5rem] shadow-xl overflow-hidden border border-cyan-100 max-w-4xl mx-auto">
		<div class="p-8 text-center sm:p-12">
			<h2 class="text-3xl font-bold text-gray-900 mb-4">Cotización del Proyecto</h2>
			<p class="text-lg text-gray-600 mb-8 max-w-2xl mx-auto">El costo depende de la profundidad y el tipo de terreno. Realizo un estudio previo del lugar para brindarle un precio final exacto.</p>
			
			<div class="bg-cyan-50 rounded-3xl p-8 md:p-10 inline-block mx-auto mb-8 border border-cyan-100">
				<span class="text-sm font-semibold text-cyan-700 uppercase tracking-wider mb-2 block">Agua es Vida</span>
				<div class="flex items-center justify-center text-cyan-700">
					<span class="text-2xl md:text-3xl font-extrabold italic">Garantía de Suministro Natural</span>
				</div>
			</div>

			<p class="text-sm text-gray-500 max-w-xl mx-auto italic">
				* Brindo servicio en toda la Península de Osa. Contácteme para más detalles técnicos.
			</p>
		</div>
	</div>
</section>

<!-- Información de Contacto -->
<section class="bg-gradient-to-br from-cyan-700 to-blue-600 text-white rounded-[3rem] shadow-2xl p-10 md:p-16 relative overflow-hidden mb-12 mx-4">
	<div class="absolute inset-0 bg-[url('https://grainy-gradients.vercel.app/noise.svg')] opacity-20 mix-blend-overlay pointer-events-none"></div>
	<div class="text-center relative z-10">
		<h2 class="text-4xl md:text-5xl font-bold mb-6 tracking-tight">¡Consiga su propio pozo hoy!</h2>
		<p class="text-cyan-100 text-lg mb-10 max-w-xl mx-auto font-light">Escríbame para consultar disponibilidad y agendar la inspección del terreno.</p>
		<div class="flex flex-col items-center">
			<a href={`https://wa.me/${seller.whatsapp.replace(/[^0-9]/g, '')}?text=Hola! Quiero cotizar la creación de un pozo artesanal`} target="_blank" rel="noopener noreferrer" class="bg-white text-cyan-800 px-12 py-4 rounded-full font-bold hover:bg-cyan-50 transition-all shadow-2xl hover:-translate-y-1 flex items-center gap-3 text-lg">
				Consultar por WhatsApp
			</a>
		</div>
	</div>
</section>
</Layout>
