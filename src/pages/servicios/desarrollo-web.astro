---
import Layout from "../../layouts/Layout.astro";

const seller = {
	name: 'Wilberth',
	email: 'info@wilberth.com',
	whatsapp: '+506 85008393'
};

export const title = 'Desarrollo de Aplicaciones Web - Wilberth'
---
<Layout seller={seller} title={title}>
<!-- Hero Section -->
<section class="bg-gradient-to-r from-green-600 to-green-800 text-white py-16 mb-12">
	<div class="max-w-4xl mx-auto text-center">
		<h1 class="text-4xl md:text-5xl font-bold mb-4">Desarrollo de Aplicaciones Web</h1>
		<p class="text-xl text-green-100 mb-8 max-w-2xl mx-auto">Creamos aplicaciones web personalizadas que impulsan el crecimiento de tu empresa. Soluciones modernas, escalables y adaptadas a tus necesidades específicas.</p>
		<a href={`https://wa.me/${seller.whatsapp.replace(/[^0-9]/g, '')}?text=Hola! Estoy interesado en desarrollo de aplicaciones web`} target="_blank" rel="noopener noreferrer" class="bg-white text-green-600 px-8 py-3 rounded-lg font-semibold hover:bg-green-50 transition-colors shadow-lg inline-block">
			Solicitar Cotización
		</a>
	</div>
</section>

<!-- Descripción del Servicio -->
<section class="mb-12">
	<div class="bg-white rounded-xl shadow-lg p-8">
		<h2 class="text-3xl font-bold text-gray-900 mb-6">¿Qué Ofrecemos?</h2>
		<p class="text-gray-600 text-lg leading-relaxed mb-4">
			Desarrollamos aplicaciones web personalizadas que se adaptan perfectamente a los procesos de tu empresa. Desde sistemas de gestión hasta plataformas de e-commerce, utilizamos las últimas tecnologías para crear soluciones robustas y eficientes.
		</p>
		<p class="text-gray-600 text-lg leading-relaxed">
			Nuestro enfoque incluye diseño responsive, integración con bases de datos, APIs modernas y una experiencia de usuario intuitiva. Cada proyecto se desarrolla siguiendo las mejores prácticas de la industria para garantizar calidad y mantenibilidad.
		</p>
	</div>
</section>

<!-- Ejemplos de Aplicaciones -->
<section class="mb-12">
	<div class="text-center mb-10">
		<h2 class="text-3xl font-bold text-gray-900 mb-3">Tipos de Aplicaciones que Desarrollamos</h2>
		<p class="text-gray-600 text-lg">Soluciones personalizadas para diferentes sectores empresariales</p>
	</div>
	<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
		<div class="bg-white rounded-xl shadow-lg overflow-hidden transition-all hover:shadow-2xl hover:-translate-y-2 duration-300">
			<div class="bg-gradient-to-br from-blue-100 to-blue-200 p-6">
				<div class="w-16 h-16 bg-blue-600 text-white rounded-full flex items-center justify-center mx-auto mb-4">
					<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path>
					</svg>
				</div>
				<h3 class="text-xl font-bold text-gray-900 mb-2">E-commerce</h3>
				<p class="text-gray-600 text-sm">Tiendas en línea completas con carrito de compras, pagos integrados y gestión de inventario.</p>
			</div>
		</div>
		<div class="bg-white rounded-xl shadow-lg overflow-hidden transition-all hover:shadow-2xl hover:-translate-y-2 duration-300">
			<div class="bg-gradient-to-br from-purple-100 to-purple-200 p-6">
				<div class="w-16 h-16 bg-purple-600 text-white rounded-full flex items-center justify-center mx-auto mb-4">
					<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
					</svg>
				</div>
				<h3 class="text-xl font-bold text-gray-900 mb-2">CRM y Gestión</h3>
				<p class="text-gray-600 text-sm">Sistemas de gestión de clientes, inventarios y procesos empresariales personalizados.</p>
			</div>
		</div>
		<div class="bg-white rounded-xl shadow-lg overflow-hidden transition-all hover:shadow-2xl hover:-translate-y-2 duration-300">
			<div class="bg-gradient-to-br from-green-100 to-green-200 p-6">
				<div class="w-16 h-16 bg-green-600 text-white rounded-full flex items-center justify-center mx-auto mb-4">
					<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path>
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
					</svg>
				</div>
				<h3 class="text-xl font-bold text-gray-900 mb-2">Portales Corporativos</h3>
				<p class="text-gray-600 text-sm">Plataformas internas para empleados, clientes o proveedores con acceso controlado.</p>
			</div>
		</div>
		<div class="bg-white rounded-xl shadow-lg overflow-hidden transition-all hover:shadow-2xl hover:-translate-y-2 duration-300">
			<div class="bg-gradient-to-br from-red-100 to-red-200 p-6">
				<div class="w-16 h-16 bg-red-600 text-white rounded-full flex items-center justify-center mx-auto mb-4">
					<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
					</svg>
				</div>
				<h3 class="text-xl font-bold text-gray-900 mb-2">Dashboards y Analytics</h3>
				<p class="text-gray-600 text-sm">Paneles de control con visualización de datos y reportes en tiempo real.</p>
			</div>
		</div>
		<div class="bg-white rounded-xl shadow-lg overflow-hidden transition-all hover:shadow-2xl hover:-translate-y-2 duration-300">
			<div class="bg-gradient-to-br from-yellow-100 to-yellow-200 p-6">
				<div class="w-16 h-16 bg-yellow-600 text-white rounded-full flex items-center justify-center mx-auto mb-4">
					<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.746 0 3.332.477 4.5 1.253v13C19.832 18.477 18.246 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path>
					</svg>
				</div>
				<h3 class="text-xl font-bold text-gray-900 mb-2">Sistemas Educativos</h3>
				<p class="text-gray-600 text-sm">Plataformas de aprendizaje en línea, LMS y sistemas de gestión académica.</p>
			</div>
		</div>
		<div class="bg-white rounded-xl shadow-lg overflow-hidden transition-all hover:shadow-2xl hover:-translate-y-2 duration-300 border-2 border-green-500">
			<div class="bg-gradient-to-br from-green-100 to-green-200 p-6">
				<div class="w-16 h-16 bg-green-600 text-white rounded-full flex items-center justify-center mx-auto mb-4">
					<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
					</svg>
				</div>
				<h3 class="text-xl font-bold text-gray-900 mb-2">Sistema Cortiz</h3>
				<p class="text-gray-600 text-sm">Sistema de cotizaciones personalizado desarrollado para empresas constructoras, con gestión de proyectos y presupuestos.</p>
			</div>
		</div>
	</div>
</section>

<!-- Información de Contacto -->
<section class="bg-gradient-to-r from-blue-600 to-blue-800 text-white rounded-2xl shadow-2xl p-8 md:p-12">
	<div class="text-center mb-8">
		<h2 class="text-3xl md:text-4xl font-bold mb-3">¿Listo para Digitalizar tu Empresa?</h2>
		<p class="text-blue-100 text-lg">Hablemos de tu proyecto y creemos juntos la aplicación web que necesitas</p>
	</div>
	<div class="flex flex-col items-center space-y-6">
		<div class="text-center">
			<div class="w-20 h-20 bg-white text-blue-600 rounded-full flex items-center justify-center mx-auto mb-4 shadow-lg">
				<svg class="w-10 h-10" fill="currentColor" viewBox="0 0 24 24">
					<path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
				</svg>
			</div>
			<h3 class="font-bold text-2xl mb-2">Contacto Directo</h3>
			<a href={`tel:${seller.whatsapp}`} class="text-3xl font-bold hover:text-blue-200 transition-colors">
				{seller.whatsapp}
			</a>
		</div>
		<div class="flex flex-col sm:flex-row gap-4">
			<a href={`https://wa.me/${seller.whatsapp.replace(/[^0-9]/g, '')}?text=Hola! Quiero desarrollar una aplicación web`} target="_blank" rel="noopener noreferrer" class="bg-green-500 hover:bg-green-600 text-white px-8 py-3 rounded-lg font-semibold transition-colors shadow-lg flex items-center gap-2">
				<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
					<path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"></path>
				</svg>
				WhatsApp
			</a>
			<a href={`mailto:${seller.email}?subject=Solicitud Desarrollo Web`} class="bg-blue-500 text-white px-8 py-3 rounded-lg font-semibold hover:bg-blue-600 transition-colors shadow-lg flex items-center gap-2">
				<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
				</svg>
				Email
			</a>
		</div>
	</div>
</section>
</Layout>