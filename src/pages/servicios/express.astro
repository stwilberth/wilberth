---
import Layout from "../../layouts/Layout.astro";

const seller = {
	name: 'Wilberth',
	email: 'info@wilberth.com',
	whatsapp: '+506 85008393'
};

export const title = 'Servicio Express - Mandados en Puerto Jiménez'
---

<Layout seller={seller} title={title}>
<!-- Hero Section -->
<section class="bg-gradient-to-r from-purple-600 to-purple-800 text-white py-16 mb-12">
	<div class="max-w-4xl mx-auto text-center">
		<h1 class="text-4xl md:text-5xl font-bold mb-4">Servicio Express</h1>
		<p class="text-xl text-purple-100 mb-8 max-w-2xl mx-auto">Trabajo con un mandado en ejecución y uno en espera, aceptando solo lo que puedo atender puntualmente.</p>
		<a href={`https://wa.me/${seller.whatsapp.replace(/[^0-9]/g, '')}?text=Hola! Estoy interesado en el servicio Express`} target="_blank" rel="noopener noreferrer" class="bg-white text-purple-600 px-8 py-3 rounded-lg font-semibold hover:bg-purple-50 transition-colors shadow-lg inline-block">
			<!-- ICONO WHATSAPP -->
			<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
				<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"></path>
			</svg>
			Solicitar Servicio
		</a>
	</div>
</section>

<!-- Método de Trabajo -->
<section class="mb-12">
	<div class="bg-white rounded-xl shadow-lg p-8">
		<h2 class="text-3xl font-bold text-gray-900 mb-6">¿Cómo Trabajamos?</h2>
		<p class="text-gray-600 text-lg leading-relaxed mb-4">
			Trabajo solo para garantizar un servicio personalizado y eficiente. Manejo un máximo de dos mandados a la vez: uno en ejecución y uno en espera.
		</p>
		<p class="text-gray-600 text-lg leading-relaxed mb-4">
			No acepto pedidos en exceso para evitar demoras y asegurar que cada mandado se realice de manera puntual y confiable. ¡Tu tiempo es valioso!
		</p>
		<p class="text-gray-600 text-lg leading-relaxed">
			Mantengo informado al cliente sobre mi ubicación, ruta y tiempo estimado de entrega. Si estoy ejecutando un pedido y tengo uno en espera, te informo para que decidas si deseas proceder o esperar.
		</p>
	</div>
</section>

<!-- Tabla de Tarifas -->
<section class="mb-12">
	<div class="bg-white rounded-xl shadow-lg overflow-hidden">
		<div class="bg-gradient-to-r from-purple-600 to-purple-800 text-white p-6">
			<h2 class="text-3xl font-bold">Tarifas del Servicio</h2>
			<p class="text-purple-100 mt-2">Precios para servicios en Puerto Jiménez</p>
		</div>
		<div class="overflow-x-auto">
			<table class="w-full">
				<thead class="bg-gray-50">
					<tr>
						<th class="px-6 py-4 text-left text-sm font-semibold text-gray-900 uppercase tracking-wider">Precio</th>
						<th class="px-6 py-4 text-left text-sm font-semibold text-gray-900 uppercase tracking-wider">Lugar</th>
						<th class="px-6 py-4 text-left text-sm font-semibold text-gray-900 uppercase tracking-wider">Descripción</th>
					</tr>
				</thead>
				<tbody class="divide-y divide-gray-200">
					<tr class="hover:bg-gray-50">
						<td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">₡800</td>
						<td class="px-6 py-4 whitespace-nowrap text-sm text-gray-600">Jiménez Centro</td>
						<td class="px-6 py-4 text-sm text-gray-600">Express General</td>
					</tr>
					<tr class="hover:bg-gray-50">
						<td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">₡1000</td>
						<td class="px-6 py-4 whitespace-nowrap text-sm text-gray-600">Bambú</td>
						<td class="px-6 py-4 text-sm text-gray-600">Express General</td>
					</tr>
					<tr class="hover:bg-gray-50">
						<td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">₡1500</td>
						<td class="px-6 py-4 whitespace-nowrap text-sm text-gray-600">Néque</td>
						<td class="px-6 py-4 text-sm text-gray-600">Express General</td>
					</tr>
					<tr class="hover:bg-gray-50">
						<td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">₡2000</td>
						<td class="px-6 py-4 whitespace-nowrap text-sm text-gray-600">Gallardo</td>
						<td class="px-6 py-4 text-sm text-gray-600">Express General</td>
					</tr>
				</tbody>
			</table>
		</div>
		<div class="bg-gray-50 px-6 py-4">
			<p class="text-sm text-gray-600">* Los precios pueden variar según la distancia, urgencia y complejidad del mandado. Contacta para cotización exacta.</p>
		</div>
	</div>
</section>

<!-- Información de Contacto -->
<section class="bg-gradient-to-r from-green-500 to-green-600 text-white rounded-2xl shadow-2xl p-8 md:p-12">
	<div class="text-center mb-8">
		<h2 class="text-3xl md:text-4xl font-bold mb-3">¡Solicita tu Mandado Ahora!</h2>
	</div>
	<div class="flex flex-col items-center space-y-6">
		<div class="text-center">
			<h3 class="font-bold text-2xl mb-4">Escanea el Código QR para WhatsApp</h3>
			<img src="/src/assets/contacto_whatsapp.jpeg" alt="QR Code WhatsApp" class="mx-auto w-32 h-32 mb-4 shadow-lg">
		</div>
		<div class="text-center">
			<div class="w-20 h-20 bg-white text-green-600 rounded-full flex items-center justify-center mx-auto mb-4 shadow-lg">
				<svg class="w-10 h-10" fill="currentColor" viewBox="0 0 24 24">
					<path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
				</svg>
			</div>
			<h3 class="font-bold text-2xl mb-2">Teléfono Principal</h3>
			<a href="tel:85008393" class="text-3xl font-bold hover:text-green-200 transition-colors">
				85008393
			</a>
		</div>
		<div class="flex flex-col sm:flex-row gap-4">
			<a href={`https://wa.me/${seller.whatsapp.replace(/[^0-9]/g, '')}?text=Hola! Quiero solicitar un servicio Express`} target="_blank" rel="noopener noreferrer" class="bg-white text-green-600 px-8 py-3 rounded-lg font-semibold hover:bg-green-50 transition-colors shadow-lg flex items-center gap-2">
				<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
					<path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"></path>
				</svg>
				WhatsApp
			</a>
		</div>
	</div>
</section>
</Layout>